# ====================================================================
#  Jazz en la Jungla — .gitignore
# ====================================================================

# ─── OS files ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── IDE / editores ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ─── Python (Lambdas) ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/
.env/

# ─── Empaquetados de Lambda ────────────────────────────────────────────
# Generados con `zip nombre.zip nombre.py` antes de update-function-code
lambdas/*.zip
*.zip

# ─── Node / front-end tooling (por si en el futuro se añade) ───────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.pnpm-store/

# ─── Variables de entorno y secretos ───────────────────────────────────
.env
.env.*
*.env
secrets.json
config.local.*
aws-credentials*
.aws/

# ─── AWS SAM / CDK / Terraform (por si se añade IaC) ───────────────────
.aws-sam/
cdk.out/
.cdk.staging/
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# ─── Logs y temporales ─────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.cache/

# ─── Capturas de pantalla locales (uso interno de desarrollo) ──────────
screenshots/
*.screenshot.png

# ─── Builds / dist ─────────────────────────────────────────────────────
dist/
build/
out/
